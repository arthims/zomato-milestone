# ─────────────────────────────────────────────
#  milestone1 — environment variable reference
#  Copy to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── LLM — Groq (Phase 4) ──────────────────────
# Required for AI-ranked recommendations.
# Get your key at https://console.groq.com/keys
#
# ⚠ IMPORTANT — remove host/IP restrictions on the key:
#   Groq Console → Keys → Edit → Allowed Origins → set to "All"
#   Otherwise you will get: 403 Host not in allowlist
GROQ_API_KEY=your-groq-api-key-here

# Optional: override the default model id.
GROQ_MODEL=llama-3.3-70b-versatile

# ── HuggingFace (Phase 1) ─────────────────────
HF_TOKEN=

# ── API server (Phase 6) ─────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Dataset (Phase 1) ─────────────────────────
LOAD_LIMIT=5000

# ── Recommendation (Phases 3-4) ───────────────
CANDIDATE_CAP=20
